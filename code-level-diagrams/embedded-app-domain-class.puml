@startuml
title Embedded App - Domain Layer Class Diagram

hide circle
skinparam classAttributeIconSize 0

class SensorReading {
  +metric: String
  +value: decimal
  +capturedAt: Instant
}

class DeviceState {
  +mode: String
  +healthy: boolean
}

class TelemetryPayload {
  +deviceId: String
  +serialize()
}

class SafetyRule {
  +name: String
  +validate(reading: SensorReading): boolean
}

class LocalCommand {
  +type: String
  +execute()
}

TelemetryPayload "1" o-- "*" SensorReading
DeviceState "1" o-- "*" SafetyRule
LocalCommand --> DeviceState

@enduml
