    - scd41Device : SCD41SensorDevice
    - pms5003Device : PMS5003SensorDevice
    - display : OLEDDisplay
    - warningLed : Led
    - currentData : ClairData
    - thresholds : AirQualityThresholds
    - wifi : WiFiService
    - edge : EdgeService
    - incidentManager : IncidentManager
    - lastReportTime : unsigned long
    - reportInterval : unsigned long
    - allSensorsReady : bool
    - simulationEnabled : bool
    - simulationStartTime : unsigned long
    - lastDisplayedStatus : AirQualityStatus
    - displayInitialized : bool
    - standbyMode : bool
    - timeSynchronized : bool
    - lastNTPSync : unsigned long
    - ntpSyncInterval : unsigned long
    - timezoneOffset : long
    + CLAIR_REPORT_COMMAND : static const int
    + CLAIR_CALIBRATE_COMMAND : static const int
    + CLAIR_RESET_COMMAND : static const int
    + REMOTE_STANDBY_COMMAND : static const int
    + REMOTE_WAKE_COMMAND : static const int
    + REMOTE_RESTART_COMMAND : static const int
    + REMOTE_SET_THRESHOLDS_COMMAND : static const int
    + LED_ON_COMMAND : static const int
