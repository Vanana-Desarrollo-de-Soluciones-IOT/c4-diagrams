    + LED_BLINK_COMMAND : static const int
    + LED_ACKNOWLEDGE_ALL : static const int
    + ClairDevice(pins : const ClairPins&, scd41Interval : unsigned long, pmsInterval : unsigned long, reportInterval : unsigned long, displaySda : int, displayScl : int)
    + ClairDevice(sda : int, scl : int, rx : int, tx : int, set : int, reset : int, scd41Interval : unsigned long, pmsInterval : unsigned long, reportInterval : unsigned long, displaySda : int, displayScl : int, ledPin : int)
    + begin() : bool
    + update()
    + on(Event event)
    + handle(Command command)
    + getCurrentData() : ClairData
    + forceReport()
    + isSystemReady() : bool
    + getSCD41Device() : SCD41SensorDevice&
    + getPMS5003Device() : PMS5003SensorDevice&
    + getDisplay() : OLEDDisplay&
    + getWarningLed() : Led&
    + setAirQualityThresholds(newThresholds : const AirQualityThresholds&)
    + getCurrentStatus() : AirQualityStatus
    + getCurrentStatusLabel() : String
    + setupEdge(baseUrl : const String&, hardwareId : const String&, deviceSecret : const String&, telemetryInterval : unsigned long, commandPollInterval : unsigned long)
    + setupIncidentManager(baseUrl : const String&, hardwareId : const String&, apiKey : const String&, pollInterval : unsigned long)
    + hasActiveIncidents() : bool
    + isStandbyMode() : bool
    + setStandbyMode(standby : bool)
