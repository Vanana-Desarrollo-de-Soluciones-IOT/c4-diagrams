@startuml
!theme plain
skinparam classAttributeIconSize 0
skinparam backgroundColor #FEFEFE
title Clair System - Class Diagram

' ============================================
' ABSTRACT BASE CLASSES (ModestIoT Framework)
' ============================================

abstract class EventHandler {
    + {abstract} on(Event event)
}

abstract class CommandHandler {
    + {abstract} handle(Command command)
}

abstract class Sensor {
    # pin : int
    # handler : EventHandler*
    + Sensor(pin : int, eventHandler : EventHandler*)
    + on(Event event)
    + setHandler(eventHandler : EventHandler*)
}

abstract class Actuator {
    # pin : int
    # handler : CommandHandler*
    + Actuator(pin : int, commandHandler : CommandHandler*)
    + handle(Command command)
    + setHandler(commandHandler : CommandHandler*)
}

abstract class Device {
    + {abstract} on(Event event)
    + {abstract} handle(Command command)
}

' ============================================
' DATA STRUCTURES
' ============================================

struct Event {
    + id : int
    + Event(eventId : int)
}

struct Command {
    + id : int
    + Command(commandId : int)
}

struct ClairData {
    + timestamp : unsigned long
    + airQuality : struct
    + particulateMatter : struct
    + airQualityIndex : struct
    + status : AirQualityStatus
    + statusLabel : String
    + statusIcon : String
    + timeFormatted : String
    + uptimeFormatted : String
    + country : String
    + calculateAQI()
    + evaluateStatus(thresholds : const AirQualityThresholds&)
    + print()
}

struct DisplayData {
    + airQuality : struct
    + particulateMatter : struct
    + aqi : struct
}

struct PMS5003Data {
    + pm1_0 : uint16_t
    + pm2_5 : uint16_t
    + pm10 : uint16_t
    + valid : bool
}

struct RemoteCommand {
    + commandId : String
    + type : String
    + parameters : String
    + valid : bool
}

struct Incident {
    + id : int
    + metric : String
    + status : String
    + occurredAt : String
    + resolvedAt : String
    + acknowledged : bool
    + print()
}

struct ClairPins {
    + scd41_sda : int
    + scd41_scl : int
    + pms_rx : int
    + pms_tx : int
    + pms_set : int
    + pms_reset : int
    + led_pin : int
}

struct AirQualityThresholds {
    + pm25ModerateLimit : uint16_t
    + pm25CriticalLimit : uint16_t
    + pm10ModerateLimit : uint16_t
    + pm10CriticalLimit : uint16_t
    + co2ModerateLimit : uint16_t
    + co2CriticalLimit : uint16_t
    + humidityModerateLow : uint8_t
    + humidityModerateHigh : uint8_t
    + humidityCriticalLow : uint8_t
    + humidityCriticalHigh : uint8_t
}

enum AirQualityStatus {
    OPTIMAL
    MODERATE
    CRITICAL
}

enum DisplayState {
    DISPLAY_ON
    DISPLAY_SLEEP
    DISPLAY_OFF
}

enum InitState {
    INIT_NOT_STARTED
    INIT_STARTING_SENSORS
    INIT_WAITING_SENSORS
    INIT_COMPLETE
    INIT_PARTIAL
}

' ============================================
' SENSOR CLASSES
' ============================================

class SCD41Sensor {
    - scd4x : SensirionI2cScd4x
    - sdaPin : int
    - sclPin : int
    - readInterval : unsigned long
    - lastReadTime : unsigned long
    - sensorInitialized : bool
    - dataValid : bool
    - lastCO2 : uint16_t
    - lastTemperature : float
    - lastHumidity : float
    - errorMessage : char[64]
    + DATA_READY_EVENT_ID : static const int
    + SCD41Sensor(sda : int, scl : int, interval : unsigned long, handler : EventHandler*)
    + begin() : bool
    + update()
    + on(Event event)
    + getCO2() : uint16_t
    + getTemperature() : float
    + getHumidity() : float
    + isInitialized() : bool
    + isDataValid() : bool
    + printSerialNumber()
    + recalibrate(targetCO2ppm : uint16_t) : bool
    + performForcedRecalibration(targetCO2ppm : uint16_t)
    - readMeasurement() : bool
}
Sensor <|-- SCD41Sensor

class SCD41SensorDevice {
    - sensor : SCD41Sensor
    + SDA_PIN : static const int
    + SCL_PIN : static const int
    + READ_INTERVAL_MS : static const unsigned long
    + SCD41SensorDevice(sdaPin : int, sclPin : int, readInterval : unsigned long)
    + on(Event event)
    + handle(Command command)
    + getSensor() : SCD41Sensor&
    + update()
}
Device <|-- SCD41SensorDevice
SCD41SensorDevice o-- SCD41Sensor

class PMS5003Sensor {
    - rxPin : int
    - txPin : int
    - setPin : int
    - resetPin : int
    - serial : HardwareSerial
    - readInterval : unsigned long
    - lastReadTime : unsigned long
    - sensorInitialized : bool
    - dataReady : bool
    - isSleeping : bool
    - lastData : PMS5003Data
    - buffer : uint8_t[32]
    - FRAME_SIZE : static const int
    + DATA_READY_EVENT_ID : static const int
    + SLEEP_MODE_EVENT_ID : static const int
    + WAKE_MODE_EVENT_ID : static const int
    + SLEEP_COMMAND_ID : static const int
    + WAKE_COMMAND_ID : static const int
    + RESET_COMMAND_ID : static const int
    + PMS5003Sensor(rxPin : int, txPin : int, setPin : int, resetPin : int, interval : unsigned long, handler : EventHandler*)
    + begin() : bool
    + update()
    + on(Event event)
    + getData() : PMS5003Data
    + sleep()
    + wake()
    + reset()
    + isInitialized() : bool
    + isSleepingMode() : bool
    - readFrame(data : PMS5003Data&) : bool
    - calculateChecksum(buffer : uint8_t*, length : int) : uint16_t
}
Sensor <|-- PMS5003Sensor

class PMS5003SensorDevice {
    - sensor : PMS5003Sensor
    + DEFAULT_RX_PIN : static const int
    + DEFAULT_TX_PIN : static const int
    + DEFAULT_SET_PIN : static const int
    + DEFAULT_RESET_PIN : static const int
    + DEFAULT_READ_INTERVAL_MS : static const unsigned long
    + PMS5003SensorDevice(rxPin : int, txPin : int, setPin : int, resetPin : int, readInterval : unsigned long)
    + on(Event event)
    + handle(Command command)
    + getSensor() : PMS5003Sensor&
    + update()
    + processSerialCommand(command : char)
}
Device <|-- PMS5003SensorDevice
PMS5003SensorDevice o-- PMS5003Sensor

' ============================================
' ACTUATOR CLASSES
' ============================================

class Led {
    - state : bool
    - blinking : bool
    - lastBlinkTime : unsigned long
    - blinkInterval : unsigned long
    - blinkState : bool
    - activeHigh : bool
    + TOGGLE_LED_COMMAND_ID : static const int
    + TURN_ON_COMMAND_ID : static const int
    + TURN_OFF_COMMAND_ID : static const int
    + START_BLINK_COMMAND_ID : static const int
    + STOP_BLINK_COMMAND_ID : static const int
    + TOGGLE_LED_COMMAND : static const Command
    + TURN_ON_COMMAND : static const Command
    + TURN_OFF_COMMAND : static const Command
    + START_BLINK_COMMAND : static const Command
    + STOP_BLINK_COMMAND : static const Command
    + Led(pin : int, initialState : bool, activeHigh : bool, commandHandler : CommandHandler*)
    + handle(Command command)
    + getState() : bool
    + setState(newState : bool)
    + on()
    + off()
    + toggle()
    + startBlink(intervalMs : unsigned long)
    + stopBlink()
    + update()
    + isBlinking() : bool
    + setBlinkInterval(intervalMs : unsigned long)
    - applyState()
    - applyBlinkState()
}
Actuator <|-- Led

class OLEDDisplay {
    - display : Adafruit_SSD1306
    - sdaPin : int
    - sclPin : int
    - i2cAddress : uint8_t
    - initialized : bool
    - currentState : DisplayState
    - lastUpdateTime : unsigned long
    - lastWakeTime : unsigned long
    - currentData : DisplayData
    - sleepAfterMs : unsigned long
    - wakeDurationMs : unsigned long
    - lineBuffer : char[32]
    + DISPLAY_UPDATE_EVENT : static const int
    + DISPLAY_WAKE_EVENT : static const int
    + DISPLAY_SLEEP_EVENT : static const int
    + DISPLAY_ON_COMMAND : static const int
    + DISPLAY_OFF_COMMAND : static const int
    + DISPLAY_SLEEP_COMMAND : static const int
    + DISPLAY_WAKE_COMMAND : static const int
    + DISPLAY_CLEAR_COMMAND : static const int
    + OLEDDisplay(width : int, height : int, sda : int, scl : int, address : uint8_t, handler : CommandHandler*)
    + begin() : bool
    + updateData(data : const DisplayData&)
    + refresh()
    + clear()
    + sleep()
    + wake()
    + off()
    + on()
    + handle(Command command)
    + autoPowerManagement()
    + isInitialized() : bool
    + getState() : DisplayState
    + setSleepTimeout(ms : unsigned long)
    - drawStatusBar()
    - drawAirQualityData()
    - drawParticulateMatterData()
    - drawAQI()
    - drawFooter()
    - getAirQualityLabel(co2 : int) : String
}
Actuator <|-- OLEDDisplay

' ============================================
' SERVICE CLASSES
' ============================================

class WiFiService {
    - wm : WiFiManager
    + WiFiService()
    + begin(unusedSSID : const String&, unusedPassword : const String&)
    + update()
    + disconnect()
    + isConnected() : bool
    + getLocalIP() : String
    + getRSSI() : int
    + printStatus()
}

class EdgeService {
    - baseUrl : String
    - hardwareId : String
    - apiKey : String
    - lastTelemetryTime : unsigned long
    - telemetryInterval : unsigned long
    - telemetryEnabled : bool
    - lastCommandPollTime : unsigned long
    - commandPollInterval : unsigned long
    - commandCallback : CommandCallback
    - commandsEnabled : bool
    - commandQueue : queue<RemoteCommand>
    - processingQueue : bool
    - lastCommandProcessTime : unsigned long
    - commandProcessDelay : unsigned long
    - telemetrySent : unsigned long
    - telemetryFailed : unsigned long
    - commandsReceived : unsigned long
    - commandsExecuted : unsigned long
    - commandsFailed : unsigned long
    - commandsQueued : unsigned long
    - httpClient : HTTPClient
    + EdgeService()
    + begin(url : const String&, id : const String&, secret : const String&, telemetryIntervalMs : unsigned long, commandPollIntervalMs : unsigned long)
    + sendTelemetry(data : const ClairData&) : bool
    + pollCommands() : bool
    + processCommandQueue()
    + setCommandCallback(callback : CommandCallback)
    + setTelemetryEnabled(enabled : bool)
    + isTelemetryEnabled() : bool
    + setCommandsEnabled(enabled : bool)
    + isCommandsEnabled() : bool
    + setCommandProcessDelay(delayMs : unsigned long)
    + getCommandQueueSize() : int
    + clearCommandQueue()
    + forceTelemetry(data : const ClairData&) : bool
    + printStats()
    - addAuthHeaders()
    - buildTelemetryPayload(data : const ClairData&) : String
    - calculateHealthStatus(data : const ClairData&) : int
    - sendAck(commandId : const String&, status : const String&, failureReason : const String&) : bool
}

class IncidentManager {
    - baseUrl : String
    - hardwareId : String
    - apiKey : String
    - pollInterval : unsigned long
    - lastPollTime : unsigned long
    - enabled : bool
    - activeIncidents : Incident[5]
    - incidentCount : int
    - pendingAcks : PendingAck[10]
    - pendingAckCount : int
    - MAX_RETRIES : static const int
    - RETRY_INTERVAL_MS : static const unsigned long
    - onIncidentDetected : void (*)(const Incident&)
    - onIncidentResolved : void (*)(const Incident&)
    - httpClient : HTTPClient
    + IncidentManager()
    + begin(url : const String&, id : const String&, key : const String&, interval : unsigned long)
    + pollIncidents() : bool
    + process()
    + forceAck(incidentId : int) : bool
    + getMetricPriority(metric : const String&) : int
    + getMostCriticalIncident() : Incident
    + hasActiveIncidents() : bool
    + getActiveCount() : int
    + getPendingAckCount() : int
    + setCallbacks(onDetect : void (*)(const Incident&), onResolve : void (*)(const Incident&))
    + printStats()
    + isEnabled() : bool
    + setEnabled(enable : bool)
    - addAuthHeaders()
    - findIncidentById(id : int) : int
    - queueAck(incidentId : int, status : const String&)
    - sendAckNow(incidentId : int) : bool
    - processPendingAcks()
    - sendAckForStatus(incidentId : int, status : const String&) : bool
    - addIncident(incident : const Incident&)
    - resolveIncident(id : int, resolvedAt : const String&)
}

struct PendingAck {
    + incidentId : int
    + status : String
    + lastAttempt : unsigned long
    + retryCount : int
    + active : bool
}

' ============================================
' MAIN DEVICE CLASS
' ============================================

