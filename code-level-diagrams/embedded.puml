    + setupWiFi(ssid : const String&, password : const String&)
    + isWiFiConnected() : bool
    + getWiFiIP() : String
    + setSimulationEnabled(enabled : bool)
    + isSimulationEnabled() : bool
    + isInitializationComplete() : bool
    + getInitStateString() : const char*
    + beginNTP(ntpServer : const char*, timezoneOffset : long)
    + updateNTP()
    + isTimeSynchronized() : bool
    + getFormattedTime() : String
    + getCurrentEpoch() : unsigned long
    - updateAirQualityData()
    - updateParticulateMatterData()
    - generateUnifiedReport()
    - checkSensorStatus()
    - refreshDisplay()
    - updateSimulationData()
    - updateInitialization()
    - updateWarningLed()
    - getAirQualityLabel(co2 : int) : String
    - {static} onIncidentDetected(incident : const Incident&)
    - {static} onIncidentResolved(incident : const Incident&)
    - {static} processRemoteCommand(cmd : const RemoteCommand&) : bool
}
Device <|-- ClairDevice
ClairDevice *-- SCD41SensorDevice
ClairDevice *-- PMS5003SensorDevice
ClairDevice *-- OLEDDisplay
ClairDevice *-- Led
ClairDevice *-- WiFiService
ClairDevice *-- EdgeService
ClairDevice *-- IncidentManager
