@startuml
title Billing - Domain Layer Class Diagram

hide circle
skinparam classAttributeIconSize 0

enum SubscriptionStatus {
  Trialing
  Active
  PastDue
  Cancelled
  Expired
}

class Plan {
  +id: PlanId
  +name: String
  +monthlyPrice: Money
  +maxDevices: int
  +historyWindowDays: int
}

class Subscription {
  +id: SubscriptionId
  +status: SubscriptionStatus
  +startedAt: Instant
  +endsAt: Instant
  +activate()
  +cancel()
  +downgrade()
}

class CheckoutSession {
  +id: CheckoutSessionId
  +providerReference: String
  +expiresAt: Instant
}

class Invoice {
  +id: InvoiceId
  +amount: Money
  +issuedAt: Instant
  +status: String
}

class Money
class PlanId
class SubscriptionId
class CheckoutSessionId
class InvoiceId

Subscription "*" --> "1" Plan
Subscription "1" o-- "*" Invoice
Subscription "1" o-- "*" CheckoutSession
Plan --> PlanId
Subscription --> SubscriptionId
CheckoutSession --> CheckoutSessionId
Invoice --> InvoiceId
Plan --> Money
Invoice --> Money

@enduml
