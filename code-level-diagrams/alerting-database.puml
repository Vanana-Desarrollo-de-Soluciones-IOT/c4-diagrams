@startuml
title Alerting & Response - Database Design Diagram

hide circle
skinparam linetype ortho

entity critical_alerts {
  * id : uuid <<PK>>
  --
  device_id : uuid
  metric : varchar
  severity : varchar
  status : varchar
  created_at : timestamp
  resolved_at : timestamp
}

entity alert_reminders {
  * id : uuid <<PK>>
  --
  alert_id : uuid <<FK>>
  sent_at : timestamp
  channel : varchar
}

entity corrective_actions {
  * id : uuid <<PK>>
  --
  alert_id : uuid <<FK>>
  action_type : varchar
  actor_type : varchar
  performed_at : timestamp
}

entity auto_response_settings {
  * id : uuid <<PK>>
  --
  device_id : uuid
  smart_alarm_enabled : boolean
  hvac_enabled : boolean
  window_actuator_enabled : boolean
}

critical_alerts ||--o{ alert_reminders
critical_alerts ||--o{ corrective_actions

@enduml
