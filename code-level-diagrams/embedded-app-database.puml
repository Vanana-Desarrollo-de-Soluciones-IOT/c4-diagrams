@startuml
title Embedded App - Local Persistence Design Diagram

hide circle
skinparam linetype ortho

entity local_runtime_state {
  * id : int <<PK>>
  --
  device_mode : varchar
  healthy : boolean
  updated_at : timestamp
}

entity local_reading_buffer {
  * id : int <<PK>>
  --
  metric : varchar
  value : decimal
  captured_at : timestamp
  published : boolean
}

entity local_command_log {
  * id : int <<PK>>
  --
  command_type : varchar
  executed_at : timestamp
  status : varchar
}

@enduml
