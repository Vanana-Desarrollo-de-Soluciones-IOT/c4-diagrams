@startuml
title Notifications - Domain Layer Class Diagram

hide circle
skinparam classAttributeIconSize 0

class NotificationTemplate {
  +id: TemplateId
  +code: String
  +channel: DeliveryChannel
}

class DeliveryRequest {
  +id: RequestId
  +recipient: String
  +status: DeliveryStatus
  +dispatch()
}

class NotificationHistory {
  +id: HistoryId
  +sentAt: Instant
  +result: DeliveryStatus
}

enum DeliveryChannel {
  Email
  Push
}

enum DeliveryStatus {
  Pending
  Sent
  Failed
}

class UserPreference {
  +id: PreferenceId
  +channel: DeliveryChannel
  +enabled: boolean
}

class TemplateId
class RequestId
class HistoryId
class PreferenceId

DeliveryRequest --> NotificationTemplate
DeliveryRequest "1" o-- "*" NotificationHistory
DeliveryRequest --> UserPreference
NotificationTemplate --> TemplateId
DeliveryRequest --> RequestId
NotificationHistory --> HistoryId
UserPreference --> PreferenceId

@enduml
