@startuml
title Air Quality Evaluation - Domain Layer Class Diagram

hide circle
skinparam classAttributeIconSize 0

class Reading {
  +id: ReadingId
  +metric: MetricType
  +value: decimal
  +capturedAt: Instant
}

enum MetricType {
  CO2
  PM25
  Humidity
  Temperature
}

class TelemetryBatch {
  +id: BatchId
  +receivedAt: Instant
  +validate()
}

class AirQualityIndex {
  +value: decimal
  +category: AirQualityState
}

enum AirQualityState {
  Good
  Moderate
  Poor
  Critical
}

class ThresholdEvaluation {
  +metric: MetricType
  +surpassed: boolean
}

class SensorAnomaly {
  +reason: String
  +detectedAt: Instant
}

class ReadingId
class BatchId

TelemetryBatch "1" o-- "*" Reading
Reading "1" --> "0..1" ThresholdEvaluation
Reading "1" --> "0..1" SensorAnomaly
TelemetryBatch --> BatchId
Reading --> ReadingId
AirQualityIndex --> AirQualityState

@enduml
