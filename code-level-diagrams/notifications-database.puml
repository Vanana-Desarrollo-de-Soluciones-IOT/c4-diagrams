@startuml
title Notifications - Database Design Diagram

hide circle
skinparam linetype ortho

entity notification_templates {
  * id : uuid <<PK>>
  --
  code : varchar
  channel : varchar
  subject : varchar
  body : text
}

entity delivery_requests {
  * id : uuid <<PK>>
  --
  template_id : uuid <<FK>>
  recipient : varchar
  status : varchar
  requested_at : timestamp
}

entity notification_history {
  * id : uuid <<PK>>
  --
  request_id : uuid <<FK>>
  sent_at : timestamp
  result : varchar
  provider_message_id : varchar
}

entity user_notification_preferences {
  * id : uuid <<PK>>
  --
  user_id : uuid
  channel : varchar
  enabled : boolean
}

notification_templates ||--o{ delivery_requests
delivery_requests ||--o{ notification_history

@enduml
