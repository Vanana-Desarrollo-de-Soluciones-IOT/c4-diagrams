@startuml
title Edge Station - Database Design Diagram

hide circle
skinparam linetype ortho

entity local_telemetry {
  * id : integer <<PK>>
  --
  device_id : varchar
  payload : text
  captured_at : timestamp
  synced : boolean
}

entity sync_queue {
  * id : integer <<PK>>
  --
  telemetry_id : integer <<FK>>
  queued_at : timestamp
  attempt_count : int
}

entity command_queue {
  * id : integer <<PK>>
  --
  device_id : varchar
  command_type : varchar
  queued_at : timestamp
  dispatched_at : timestamp
}

entity sync_checkpoints {
  * id : integer <<PK>>
  --
  last_synced_at : timestamp
  cursor : varchar
}

local_telemetry ||--o{ sync_queue

@enduml
